{
  "name": "demo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "test:qa": "docker run --rm -w /app --env TEST_ENV=qa --env-file ./config/.env.qa -v \"%cd%:/app\" demo",
    "test:qa:all": "npm run test:qa -- --project all",
    "test:qa:smoke": "npm run test:qa -- --project smoke",
    "test:qa:api": "npm run test:qa -- --project api",
    "test:qa:ui": "npm run test:qa -- --project ui",
    "test:qa:update-snapshots": "npm run test:qa -- --project visual --update-snapshots",
    "test:qa:visual": "npm run test:qa -- --project visual",
    "test:prod": "docker run --rm -w /app --env TEST_ENV=prod --env-file ./config/.env.prod -v \"%cd%:/app\" demo",
    "test:prod:all": "npm run test:prod -- --project all",
    "test:prod:smoke": "npm run test:prod -- --project smoke",
    "test:prod:api": "npm run test:prod -- --project api",
    "test:prod:ui": "npm run test:prod -- --project ui",
    "test:prod:update-snapshots": "npm run test:prod -- --project visual --update-snapshots",
    "test:prod:visual": "npm run test:prod -- --project visual",
    "test:qa:api:local": "cross-env TEST_ENV=qa WORKERS=4 npx playwright test --project=api",
    "test:qa:ui:headed": "cross-env TEST_ENV=qa WORKERS=1 npx playwright test --project=setup --project=ui --headed",
    "test:prod:ui:headed": "cross-env TEST_ENV=prod WORKERS=1 npx playwright test --project=setup --project=ui --headed",
    "test:ci:api": "playwright test --project=api",
    "test:ci:ui": "playwright test --project=setup --project=ui",
    "test:ci:visual": "playwright test --project=setup --project=visual",
    "test:ci:update-snapshots": "playwright test --project=setup --project=visual --update-snapshots",
    "report:default": "npx playwright show-report",
    "report:open": "npx playwright show-report playwright-report",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pdf-parse": "^1.1.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.53.1"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
